/// 環境設定ファイル（Git 管理対象外）
///
/// セットアップ手順:
///   1. このファイルを env.dart にコピー
///   2. WORKER_BASE_URL に実際の Cloudflare Worker URL を入力
///
/// cp lib/config/env.dart.example lib/config/env.dart
class Env {
  /// Cloudflare Worker のベース URL
  /// 例: https://svarga-admin-api.YOUR_ACCOUNT.workers.dev
  static const String workerBaseUrl = 'https://YOUR_WORKER_URL';
}
